interval 15m

source btc = binance.usdm("BTCUSDT")
source btc_spot = binance.spot("BTCUSDT")
execution btc = binance.usdm("BTCUSDT")
use btc 1h
use btc 4h

source eth = binance.usdm("ETHUSDT")
source eth_spot = binance.spot("ETHUSDT")
execution eth = binance.usdm("ETHUSDT")
use eth 1h
use eth 4h

source sol = binance.usdm("SOLUSDT")
source sol_spot = binance.spot("SOLUSDT")
execution sol = binance.usdm("SOLUSDT")
use sol 1h
use sol 4h

source xrp = binance.usdm("XRPUSDT")
source xrp_spot = binance.spot("XRPUSDT")
execution xrp = binance.usdm("XRPUSDT")
use xrp 1h
use xrp 4h

source doge = binance.usdm("DOGEUSDT")
source doge_spot = binance.spot("DOGEUSDT")
execution doge = binance.usdm("DOGEUSDT")
use doge 1h
use doge 4h

source bnb = binance.usdm("BNBUSDT")
source bnb_spot = binance.spot("BNBUSDT")
execution bnb = binance.usdm("BNBUSDT")
use bnb 1h
use bnb 4h

source ada = binance.usdm("ADAUSDT")
source ada_spot = binance.spot("ADAUSDT")
execution ada = binance.usdm("ADAUSDT")
use ada 1h
use ada 4h

source link = binance.usdm("LINKUSDT")
source link_spot = binance.spot("LINKUSDT")
execution link = binance.usdm("LINKUSDT")
use link 1h
use link 4h

source avax = binance.usdm("AVAXUSDT")
source avax_spot = binance.spot("AVAXUSDT")
execution avax = binance.usdm("AVAXUSDT")
use avax 1h
use avax 4h

source dot = binance.usdm("DOTUSDT")
source dot_spot = binance.spot("DOTUSDT")
execution dot = binance.usdm("DOTUSDT")
use dot 1h
use dot 4h

portfolio_group "binance_top10" = [btc, eth, sol, xrp, doge, bnb, ada, link, avax, dot]
max_positions = 10
max_long_positions = 6
max_short_positions = 6
max_gross_exposure_pct = 6.0
max_net_exposure_pct = 3.0

// Experimental 15m Binance USD-M top-10 major-coin basket. The basket is
// based on current high-liquidity large-cap perps with multi-year history:
// BTC, ETH, SOL, XRP, DOGE, BNB, ADA, LINK, AVAX, DOT. Dynamic single-leg
// routing lets the same signal stack trade every selected execution alias with
// venue = current_execution().
input basis_len = 34 optimize(int, 20, 55, 1)
input band_dev = 1.9 optimize(float, 1.4, 2.6, 0.1)
input stretch_len = 96 optimize(int, 48, 144, 4)
input rsi_len = 8 optimize(int, 4, 12, 1)
input atr_len = 12 optimize(int, 7, 20, 1)
input adx_len = 14 optimize(int, 8, 20, 1)
input trend_fast_len = 21 optimize(int, 13, 34, 1)
input trend_slow_len = 55 optimize(int, 34, 89, 1)
input macro_fast_len = 13 optimize(int, 8, 21, 1)
input macro_slow_len = 34 optimize(int, 21, 55, 1)
input trend_gap_bps = 38 optimize(float, 10, 80, 2)
input macro_gap_bps = 55 optimize(float, 20, 120, 5)
input trend_adx_floor = 20 optimize(float, 12, 30, 1)
input range_adx_cap = 17 optimize(float, 10, 26, 1)
input spread_len = 96 optimize(int, 48, 144, 4)
input spread_cap_bps = 22 optimize(float, 8, 40, 1)
input spread_z_cap = 2.3 optimize(float, 1.2, 3.2, 0.1)
input volatility_z_cap = 2.0 optimize(float, 1.0, 3.5, 0.1)
input huge_bar_atr = 2.4 optimize(float, 1.4, 4.0, 0.1)
input range_entry_z = 1.35 optimize(float, 0.8, 2.2, 0.05)
input trend_pullback_z = 0.55 optimize(float, 0.2, 1.2, 0.05)
input range_long_rsi = 36 optimize(int, 25, 45, 1)
input range_short_rsi = 64 optimize(int, 55, 75, 1)
input trend_long_rsi = 42 optimize(int, 34, 52, 1)
input trend_short_rsi = 58 optimize(int, 48, 66, 1)
input range_exit_z = 0.15 optimize(float, 0.0, 0.6, 0.05)
input trend_exit_z = 0.05 optimize(float, 0.0, 0.4, 0.05)
input cooldown_bars = 1 optimize(int, 0, 6, 1)
input protect_cooldown_bars = 4 optimize(int, 0, 8, 1)
input range_hold_bars = 16 optimize(int, 4, 32, 1)
input trend_hold_bars = 28 optimize(int, 8, 48, 2)
input range_stop_atr = 0.80 optimize(float, 0.5, 1.6, 0.05)
input trend_stop_atr = 1.05 optimize(float, 0.7, 2.0, 0.05)
input range_target1_atr = 0.75 optimize(float, 0.3, 1.2, 0.05)
input range_target2_atr = 1.70 optimize(float, 0.8, 2.6, 0.05)
input trend_target1_atr = 1.10 optimize(float, 0.5, 1.8, 0.05)
input trend_target2_atr = 2.70 optimize(float, 1.0, 3.8, 0.1)
input range_lock_atr = 0.00 optimize(float, 0.0, 0.5, 0.05)
input range_lock2_atr = 0.35 optimize(float, 0.0, 0.8, 0.05)
input trend_lock_atr = 0.35 optimize(float, 0.0, 0.8, 0.05)
input trend_lock2_atr = 1.10 optimize(float, 0.0, 1.8, 0.05)
input range_target1_size = 0.60 optimize(float, 0.3, 0.8, 0.05)
input range_target2_size = 0.25 optimize(float, 0.1, 0.4, 0.05)
input trend_target1_size = 0.45 optimize(float, 0.2, 0.7, 0.05)
input trend_target2_size = 0.35 optimize(float, 0.1, 0.5, 0.05)
input range_size_fraction = 0.06 optimize(float, 0.02, 0.15, 0.01)
input trend_size_fraction = 0.08 optimize(float, 0.02, 0.15, 0.01)

fn pick_current(btc_value, eth_value, sol_value, xrp_value, doge_value, bnb_value, ada_value, link_value, avax_value, dot_value) = current_execution() == btc ? btc_value : current_execution() == eth ? eth_value : current_execution() == sol ? sol_value : current_execution() == xrp ? xrp_value : current_execution() == doge ? doge_value : current_execution() == bnb ? bnb_value : current_execution() == ada ? ada_value : current_execution() == link ? link_value : current_execution() == avax ? avax_value : dot_value

let current_open = pick_current(btc.open, eth.open, sol.open, xrp.open, doge.open, bnb.open, ada.open, link.open, avax.open, dot.open)
let current_high = pick_current(btc.high, eth.high, sol.high, xrp.high, doge.high, bnb.high, ada.high, link.high, avax.high, dot.high)
let current_low = pick_current(btc.low, eth.low, sol.low, xrp.low, doge.low, bnb.low, ada.low, link.low, avax.low, dot.low)
let current_close = pick_current(btc.close, eth.close, sol.close, xrp.close, doge.close, bnb.close, ada.close, link.close, avax.close, dot.close)
let current_time = pick_current(btc.time, eth.time, sol.time, xrp.time, doge.time, bnb.time, ada.time, link.time, avax.time, dot.time)
let current_spot_close = pick_current(btc_spot.close, eth_spot.close, sol_spot.close, xrp_spot.close, doge_spot.close, bnb_spot.close, ada_spot.close, link_spot.close, avax_spot.close, dot_spot.close)
let current_1h_close = pick_current(btc.1h.close, eth.1h.close, sol.1h.close, xrp.1h.close, doge.1h.close, bnb.1h.close, ada.1h.close, link.1h.close, avax.1h.close, dot.1h.close)
let current_4h_close = pick_current(btc.4h.close, eth.4h.close, sol.4h.close, xrp.4h.close, doge.4h.close, bnb.4h.close, ada.4h.close, link.4h.close, avax.4h.close, dot.4h.close)

let basis = ema(current_close, basis_len)
let (upper_band, mid_band, lower_band) = bbands(current_close, basis_len, band_dev, band_dev, ma_type.ema)
let stretch_value = zscore(current_close - basis, stretch_len)
let fast_rsi = rsi(current_close, rsi_len)
let atr_base = atr(current_high, current_low, current_close, atr_len)
let natr_base = natr(current_high, current_low, current_close, atr_len)
let volatility_z = zscore(natr_base, spread_len)
let adx_value = adx(current_high, current_low, current_close, adx_len)
let trend_fast = ema(current_1h_close, trend_fast_len)
let trend_slow = ema(current_1h_close, trend_slow_len)
let macro_fast = ema(current_4h_close, macro_fast_len)
let macro_slow = ema(current_4h_close, macro_slow_len)
let trend_gap_bps_now = trend_slow > 0 ? ((trend_fast - trend_slow) / trend_slow) * 10000 : 0
let macro_gap_bps_now = macro_slow > 0 ? ((macro_fast - macro_slow) / macro_slow) * 10000 : 0
let trend_gap_abs_bps = trend_gap_bps_now >= 0 ? trend_gap_bps_now : -trend_gap_bps_now
let macro_gap_abs_bps = macro_gap_bps_now >= 0 ? macro_gap_bps_now : -macro_gap_bps_now
let spread_bps = current_spot_close > 0 ? ((current_close - current_spot_close) / current_spot_close) * 10000 : na
let spread_abs_bps = spread_bps >= 0 ? spread_bps : -spread_bps
let spread_z = zscore(spread_bps, spread_len)
let spread_abs_z = spread_z >= 0 ? spread_z : -spread_z
let bar_range = current_high - current_low
let bar_range_atr = atr_base > 0 ? bar_range / atr_base : 0
let candle_top = current_close > current_open ? current_close : current_open
let candle_bottom = current_close < current_open ? current_close : current_open
let upper_wick = current_high - candle_top
let lower_wick = candle_bottom - current_low
let bullish_reversal_bar = current_close > current_open and lower_wick > upper_wick
let bearish_reversal_bar = current_close < current_open and upper_wick > lower_wick
let spread_ok = spread_abs_bps < spread_cap_bps and spread_abs_z < spread_z_cap
let volatility_ok = volatility_z < volatility_z_cap
let bar_ok = bar_range_atr < huge_bar_atr
let trend_up = trend_gap_bps_now > trend_gap_bps and macro_gap_bps_now > macro_gap_bps and current_1h_close > trend_slow and current_4h_close > macro_slow
let trend_down = trend_gap_bps_now < -trend_gap_bps and macro_gap_bps_now < -macro_gap_bps and current_1h_close < trend_slow and current_4h_close < macro_slow
let trend_mode = adx_value > trend_adx_floor and (trend_up or trend_down)
let range_mode = adx_value < range_adx_cap and trend_gap_abs_bps < trend_gap_bps and macro_gap_abs_bps < macro_gap_bps
let recent_long_protect_exit = coalesce(last_long_exit.kind == exit_kind.protect and barssince(position_event.long_protect_fill) < protect_cooldown_bars, false)
let recent_short_protect_exit = coalesce(last_short_exit.kind == exit_kind.protect and barssince(position_event.short_protect_fill) < protect_cooldown_bars, false)
let range_long_setup = range_mode and stretch_value < -range_entry_z and current_close < lower_band and fast_rsi < range_long_rsi and bullish_reversal_bar and recent_long_protect_exit == false
let range_short_setup = range_mode and stretch_value > range_entry_z and current_close > upper_band and fast_rsi > range_short_rsi and bearish_reversal_bar and recent_short_protect_exit == false
let trend_long_setup = trend_mode and trend_up and stretch_value < -trend_pullback_z and current_low < basis and current_close > current_open and fast_rsi < trend_long_rsi and fast_rsi > fast_rsi[1] and recent_long_protect_exit == false
let trend_short_setup = trend_mode and trend_down and stretch_value > trend_pullback_z and current_high > basis and current_close < current_open and fast_rsi > trend_short_rsi and fast_rsi < fast_rsi[1] and recent_short_protect_exit == false
let long_trend_trade = coalesce(valuewhen(position_event.long_entry_fill, trend_mode and trend_up, 0), false)
let short_trend_trade = coalesce(valuewhen(position_event.short_entry_fill, trend_mode and trend_down, 0), false)

cooldown long = cooldown_bars
cooldown short = cooldown_bars

entry long = spread_ok and volatility_ok and bar_ok and (range_long_setup or trend_long_setup)
entry short = spread_ok and volatility_ok and bar_ok and (range_short_setup or trend_short_setup)
exit long = long_trend_trade ? (stretch_value > trend_exit_z or current_close > basis or fast_rsi > 55 or trend_up == false or position.bars_held >= trend_hold_bars) : (stretch_value > -range_exit_z or current_close > mid_band or fast_rsi > 52 or position.bars_held >= range_hold_bars)
exit short = short_trend_trade ? (stretch_value < -trend_exit_z or current_close < basis or fast_rsi < 45 or trend_down == false or position.bars_held >= trend_hold_bars) : (stretch_value < range_exit_z or current_close < mid_band or fast_rsi < 48 or position.bars_held >= range_hold_bars)

order entry long = market(venue = current_execution())
order exit long = market(venue = current_execution())
order entry short = market(venue = current_execution())
order exit short = market(venue = current_execution())
size entry long = capital_fraction(trend_long_setup ? trend_size_fraction : range_size_fraction)
size entry short = capital_fraction(trend_short_setup ? trend_size_fraction : range_size_fraction)

protect long = stop_market(
    trigger_price = trail_stop_long(position.entry_price, (long_trend_trade ? trend_stop_atr : range_stop_atr) * atr_base),
    trigger_ref = trigger_ref.mark,
    venue = current_execution()
)
target1 long = take_profit_market(
    trigger_price = position.entry_price + (long_trend_trade ? trend_target1_atr : range_target1_atr) * atr_base,
    trigger_ref = trigger_ref.mark,
    venue = current_execution()
)
size target1 long = long_trend_trade ? trend_target1_size : range_target1_size
protect_after_target1 long = stop_market(
    trigger_price = break_even_long(position.entry_price, (long_trend_trade ? trend_lock_atr : range_lock_atr) * atr_base),
    trigger_ref = trigger_ref.mark,
    venue = current_execution()
)
target2 long = take_profit_market(
    trigger_price = position.entry_price + (long_trend_trade ? trend_target2_atr : range_target2_atr) * atr_base,
    trigger_ref = trigger_ref.mark,
    venue = current_execution()
)
size target2 long = long_trend_trade ? trend_target2_size : range_target2_size
protect_after_target2 long = stop_market(
    trigger_price = break_even_long(position.entry_price, (long_trend_trade ? trend_lock2_atr : range_lock2_atr) * atr_base),
    trigger_ref = trigger_ref.mark,
    venue = current_execution()
)

protect short = stop_market(
    trigger_price = trail_stop_short(position.entry_price, (short_trend_trade ? trend_stop_atr : range_stop_atr) * atr_base),
    trigger_ref = trigger_ref.mark,
    venue = current_execution()
)
target1 short = take_profit_market(
    trigger_price = position.entry_price - (short_trend_trade ? trend_target1_atr : range_target1_atr) * atr_base,
    trigger_ref = trigger_ref.mark,
    venue = current_execution()
)
size target1 short = short_trend_trade ? trend_target1_size : range_target1_size
protect_after_target1 short = stop_market(
    trigger_price = break_even_short(position.entry_price, (short_trend_trade ? trend_lock_atr : range_lock_atr) * atr_base),
    trigger_ref = trigger_ref.mark,
    venue = current_execution()
)
target2 short = take_profit_market(
    trigger_price = position.entry_price - (short_trend_trade ? trend_target2_atr : range_target2_atr) * atr_base,
    trigger_ref = trigger_ref.mark,
    venue = current_execution()
)
size target2 short = short_trend_trade ? trend_target2_size : range_target2_size
protect_after_target2 short = stop_market(
    trigger_price = break_even_short(position.entry_price, (short_trend_trade ? trend_lock2_atr : range_lock2_atr) * atr_base),
    trigger_ref = trigger_ref.mark,
    venue = current_execution()
)

export current_hour_utc = hour_utc(current_time)
export stretch_signal = stretch_value
export fast_rsi_signal = fast_rsi
export adx_signal = adx_value
export trend_gap_signal_bps = trend_gap_bps_now
export macro_gap_signal_bps = macro_gap_bps_now
export spread_signal_bps = spread_bps
export volatility_z_signal = volatility_z
export range_mode_state = range_mode
export trend_mode_state = trend_mode
export trend_up_state = trend_up
export trend_down_state = trend_down
export range_long_setup_state = range_long_setup
export range_short_setup_state = range_short_setup
export trend_long_setup_state = trend_long_setup
export trend_short_setup_state = trend_short_setup

plot(stretch_value)
