interval 1h
source perp = binance.usdm("BTCUSDT")
use perp 4h

let mark_basis = perp.mark_price - perp.index_price
let funding_bias = nz(perp.funding_rate, 0)
let higher_tf_premium = ema(perp.4h.premium_index, 4)

export funding = funding_bias
export basis = perp.basis
export mark_basis_signal = mark_basis

plot(mark_basis + funding_bias)
plot(higher_tf_premium)
