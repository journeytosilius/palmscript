interval 1d
source spot = binance.spot("BTCUSDT")
use spot 1w

// Multi-interval example using weekly context on a daily execution feed.
let weekly_basis = ema(spot.1w.close, 2)

export above_weekly_basis = spot.close > weekly_basis
trigger continuation = above_weekly_basis and spot.close > spot.close[1]

if continuation {
    plot(1)
} else if above_weekly_basis {
    plot(0.5)
} else {
    plot(0)
}
