interval 1m
source spot = binance.spot("BTCUSDT")

let fast = ema(spot.close, 5)
let slow = ema(spot.close, 13)
let momentum = roc(spot.close, 3)
let range = highest(spot.close, 5) - lowest(spot.close, 5)

export above_basis = above(fast, slow)
trigger cross_up = crossover(fast, slow)

if above(fast, slow) and rising(spot.close, 2) {
    plot(momentum + range)
} else {
    plot(na)
}
